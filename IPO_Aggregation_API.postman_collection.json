{
  "info": {
    "name": "IPO Aggregation API v3",
    "description": "IPO Aggregation Platform — list IPOs, resolve PDFs into sections, parse via Firecrawl, get unified data. \n\nBase URLs:\n  Local:    http://127.0.0.1:8001\n  Railway:  https://ipobackend-production.up.railway.app\n\nAuth: Write endpoints (resolve, parse-firecrawl, refresh) require X-Internal-Key header.\nDocs: https://ipobackend-production.up.railway.app/docs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "IPOs",
      "item": [
        {
          "name": "List All IPOs",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos", "host": ["{{base_url}}"], "path": ["api", "ipos"] } }
        },
        {
          "name": "List with Filters",
          "description": "Filters: documents=drhp,rhp | search=genxai | year=2026 | status=upcoming | publish_status=published | limit=50",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos?documents=drhp,rhp&year=2026&limit=20", "host": ["{{base_url}}"], "path": ["api", "ipos"], "query": [{ "key": "documents", "value": "drhp,rhp" }, { "key": "year", "value": "2026" }, { "key": "limit", "value": "20" }] } }
        },
        {
          "name": "Search by Name",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos?search=genxai&documents=any", "host": ["{{base_url}}"], "path": ["api", "ipos"], "query": [{ "key": "search", "value": "genxai" }, { "key": "documents", "value": "any" }] } }
        },
        {
          "name": "Filter: Published Only",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos?publish_status=published", "host": ["{{base_url}}"], "path": ["api", "ipos"], "query": [{ "key": "publish_status", "value": "published" }] } }
        }
      ]
    },
    {
      "name": "IPO Detail",
      "item": [
        {
          "name": "Get IPO by ID",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos/3230", "host": ["{{base_url}}"], "path": ["api", "ipos", "3230"] } }
        },
        {
          "name": "Get Documents Overview",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos/3230/documents", "host": ["{{base_url}}"], "path": ["api", "ipos", "3230", "documents"] } }
        }
      ]
    },
    {
      "name": "Unified Data (Main Contract)",
      "item": [
        {
          "name": "Get Unified Data",
          "description": "THE endpoint. Returns all extracted fields as flat JSON. 50+ fields: dates, shares, financials, ratios, contacts, fund usage, computed application_lot_table. Values in crores.\n\nFields include: bid_open/close/allotment/listing/refund/credit dates, QIB/NII/Retail/MM/Employee shares, authorized/paid-up/pre/post shares, EPS/NAV/RoNW/ROCE/DebtEq ratios, registrar/BRLM contacts, fund usage breakdown, application lot table.",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos/3230/unified", "host": ["{{base_url}}"], "path": ["api", "ipos", "3230", "unified"] } }
        },
        {
          "name": "Get Unified (Alias)",
          "description": "Alias for /unified. Kept for backwards compatibility.",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos/3230/parsed-all", "host": ["{{base_url}}"], "path": ["api", "ipos", "3230", "parsed-all"] } }
        }
      ]
    },
    {
      "name": "Sections (Resolve + View)",
      "item": [
        {
          "name": "Resolve Documents (Background)",
          "description": "Downloads RHP/DRHP PDF, detects sections by header matching (25+ variants), extracts each section's text using pdfplumber (with table detection via find_tables), saves raw_md + extracted tables to DB + R2.\n\nReturns task_id. Poll GET /api/tasks/{task_id} for progress. Requires X-Internal-Key.",
          "request": { "method": "POST", "header": [{ "key": "X-Internal-Key", "value": "{{internal_key}}", "type": "text" }], "url": { "raw": "{{base_url}}/api/ipos/3230/resolve", "host": ["{{base_url}}"], "path": ["api", "ipos", "3230", "resolve"] } }
        },
        {
          "name": "Resolve All Pending",
          "description": "Batch resolves all IPOs that have documents not yet resolved. Requires X-Internal-Key.",
          "request": { "method": "POST", "header": [{ "key": "X-Internal-Key", "value": "{{internal_key}}", "type": "text" }], "url": { "raw": "{{base_url}}/api/ipos/resolve-all-pending", "host": ["{{base_url}}"], "path": ["api", "ipos", "resolve-all-pending"] } }
        },
        {
          "name": "List Sections (RHP)",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos/3230/documents/rhp/sections", "host": ["{{base_url}}"], "path": ["api", "ipos", "3230", "documents", "rhp", "sections"] } }
        },
        {
          "name": "View Section Raw Text",
          "description": "Returns raw markdown text for a specific section (includes pdfplumber-extracted tables as pipe syntax).",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos/3230/documents/rhp/sections/CAPITAL_STRUCTURE", "host": ["{{base_url}}"], "path": ["api", "ipos", "3230", "documents", "rhp", "sections", "CAPITAL_STRUCTURE"] } }
        },
        {
          "name": "List Sections (DRHP)",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos/3230/documents/drhp/sections", "host": ["{{base_url}}"], "path": ["api", "ipos", "3230", "documents", "drhp", "sections"] } }
        }
      ]
    },
    {
      "name": "Firecrawl Parsing",
      "item": [
        {
          "name": "Parse with Firecrawl",
          "description": "Sends section raw_md in groups (company, structure, financial, issue) to Firecrawl LLM with JSON schema. Returns structured field data per section. Builds unified_data automatically. ~4 Firecrawl calls per IPO (~20 credits, ~$0.017). Requires X-Internal-Key.",
          "request": { "method": "POST", "header": [{ "key": "X-Internal-Key", "value": "{{internal_key}}", "type": "text" }], "url": { "raw": "{{base_url}}/api/ipos/3230/parse-firecrawl", "host": ["{{base_url}}"], "path": ["api", "ipos", "3230", "parse-firecrawl"] } }
        },
        {
          "name": "Parse Firecrawl (Force Re-parse)",
          "description": "Force re-parse even if hashes match. Use after schema changes or resolve updates. Requires X-Internal-Key.",
          "request": { "method": "POST", "header": [{ "key": "X-Internal-Key", "value": "{{internal_key}}", "type": "text" }], "url": { "raw": "{{base_url}}/api/ipos/3230/parse-firecrawl?force=true", "host": ["{{base_url}}"], "path": ["api", "ipos", "3230", "parse-firecrawl"], "query": [{ "key": "force", "value": "true" }] } }
        }
      ]
    },
    {
      "name": "Tables API",
      "item": [
        {
          "name": "Get All Tables",
          "description": "Returns all tables extracted during resolve, in structured JSON format (headers + rows per table). Tables are detected via pdfplumber find_tables().",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos/3230/tables", "host": ["{{base_url}}"], "path": ["api", "ipos", "3230", "tables"] } }
        },
        {
          "name": "Get Tables (Filtered)",
          "description": "Filter by doc_type and/or section_name.",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/ipos/3230/tables?doc_type=rhp&section_name=CAPITAL_STRUCTURE", "host": ["{{base_url}}"], "path": ["api", "ipos", "3230", "tables"], "query": [{ "key": "doc_type", "value": "rhp" }, { "key": "section_name", "value": "CAPITAL_STRUCTURE" }] } }
        }
      ]
    },
    {
      "name": "Background Tasks",
      "item": [
        {
          "name": "List Recent Tasks",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/tasks?limit=10", "host": ["{{base_url}}"], "path": ["api", "tasks"], "query": [{ "key": "limit", "value": "10" }] } }
        },
        {
          "name": "Poll Task Status",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/tasks/abc123", "host": ["{{base_url}}"], "path": ["api", "tasks", "abc123"] } }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] } }
        },
        {
          "name": "Trigger Scrape (Background)",
          "description": "Full re-scrape from Upstox, BSE, NSE, SEBI. Returns task_id. Requires X-Internal-Key.",
          "request": { "method": "POST", "header": [{ "key": "X-Internal-Key", "value": "{{internal_key}}", "type": "text" }], "url": { "raw": "{{base_url}}/api/refresh", "host": ["{{base_url}}"], "path": ["api", "refresh"] } }
        },
        {
          "name": "Scrape by Year",
          "description": "Only saves IPOs filed in 2026. Requires X-Internal-Key.",
          "request": { "method": "POST", "header": [{ "key": "X-Internal-Key", "value": "{{internal_key}}", "type": "text" }], "url": { "raw": "{{base_url}}/api/refresh?year=2026", "host": ["{{base_url}}"], "path": ["api", "refresh"], "query": [{ "key": "year", "value": "2026" }] } }
        },
        {
          "name": "Dashboard Stats",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/dashboard/stats", "host": ["{{base_url}}"], "path": ["api", "dashboard", "stats"] } }
        },
        {
          "name": "Status Changes",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/api/status-changes?limit=20", "host": ["{{base_url}}"], "path": ["api", "status-changes"], "query": [{ "key": "limit", "value": "20" }] } }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "https://ipobackend-production.up.railway.app", "type": "string" },
    { "key": "internal_key", "value": "bc13ad...0d34", "type": "string" }
  ]
}
