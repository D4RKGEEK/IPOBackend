# IPO Aggregation Platform - Environment Variables

# ─── DeepSeek (section parsing) ─────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cloudflare R2 (section markdown storage) ───────────────────────
# Used to host extracted section .md files at public URLs so external
# tools (Firecrawl, etc.) can fetch them by URL.
CF_ACCOUNT_ID=                              # 32-char hex, top-right of CF dashboard
R2_ACCESS_KEY_ID=                           # From R2 -> Manage API Tokens
R2_SECRET_ACCESS_KEY=                       # Shown once when token is created
R2_BUCKET=ipo                               # Bucket name (lowercase, no underscores)
R2_PUBLIC_BASE=https://pub-xxxxxxxx.r2.dev  # From bucket -> Settings -> Public access

# ─── Firecrawl (section parsing) ────────────────────────────────────
# Sends each section's hosted R2 URL to Firecrawl /scrape with a JSON schema
# to get structured fields back. Smaller, more targeted than full-PDF DeepSeek.
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PARSER_PROVIDER=deepseek                    # deepseek | firecrawl

# ─── Database (production: Postgres via Supabase) ───────────────────
# If set, the app uses Postgres. If blank, falls back to local SQLite (ipos.db).
# Get the URL from Supabase → Project Settings → Database → Connection string
# (use the "Session" pooler URL, port 5432, NOT the transaction pooler).
DATABASE_URL=

# ─── Internal auth (gates POST /api/refresh from external cron) ─────
# Set to a long random string in production: `openssl rand -hex 32`
# When blank, the gate is open (fine for local dev, NOT for production).
INTERNAL_API_KEY=

# ─── Notifications (optional; blank = disabled) ─────────────────────
# Telegram — instant pings (info / warn / error). Set both to enable.
# Setup:
#   1. Talk to @BotFather on Telegram → /newbot → copy the token
#   2. Send any message to your new bot
#   3. curl https://api.telegram.org/bot<TOKEN>/getUpdates → find your chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gmail — for errors + daily digests. Needs an App Password, NOT your login pwd.
# Setup: myaccount.google.com → Security → 2-step verification → App passwords
GMAIL_USER=
GMAIL_APP_PASSWORD=
NOTIFY_RECIPIENT_EMAIL=     # usually same as GMAIL_USER

# ─── Application ────────────────────────────────────────────────────
APP_NAME=IPO Aggregation Platform
VERSION=3.0.0
DEBUG=True

# ─── Rate limiting (per-source) ─────────────────────────────────────
SEBI_DELAY_SECONDS=0.3
BSE_DELAY_SECONDS=0.1
NSE_DELAY_SECONDS=0.1
BSE_SME_DELAY_SECONDS=0.5

# ─── Document handling ──────────────────────────────────────────────
MAX_DOCUMENT_SIZE_MB=50
