# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_service_role_key
SUPABASE_SERVICE_ROLE=your_service_role_key

# Database Configuration
DATABASE_URL=your_database_url

# Application Configuration
APP_NAME=IPO Aggregation Platform
VERSION=2.1.0
DEBUG=True

# Scraping Configuration
SEBI_BASE_URL=https://www.sebi.gov.in
NSE_BASE_URL=https://www.nseindia.com
BSE_BASE_URL=https://api.bseindia.com
BSE_SME_URL=https://www.bsesme.com

# Rate Limiting
SEBI_DELAY_SECONDS=0.3
BSE_DELAY_SECONDS=0.1
NSE_DELAY_SECONDS=0.1
BSE_SME_DELAY_SECONDS=0.5

# Document Storage
DOCUMENT_CACHE_DIR=./.doc_cache
MAX_DOCUMENT_SIZE_MB=50
CLEANUP_DAYS_OLD=30